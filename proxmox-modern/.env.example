# PLATFORM_API_KEY is the dp_… key from https://deploy.21mv.com/dashboard/keys
# It authenticates BOTH the deploy API and the mail proxy.
PLATFORM_API_KEY=dp_replace_me

# DATABASE_URL is auto-injected by the platform per-app.
# Leave unset locally (the app gracefully no-ops) or set a local Postgres for dev.
# DATABASE_URL=postgres://user:pass@localhost:5432/proxmox
